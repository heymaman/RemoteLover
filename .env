# ─── Database ───
DB_PATH=data/jobs.db

# ─── Scraper Performance ───
MAX_CONCURRENT=10
REQUEST_TIMEOUT=30
MAX_RETRIES=3
BASE_DELAY=1.0
MAX_RESULTS_PER_SOURCE=100
BATCH_SIZE=500

# ─── Feature Flags ───
ENABLE_SOURCE_DISCOVERY=true
ENABLE_GOOGLE_SEARCH=true
ENABLE_JOBSPY=true
ENABLE_YC=true
ENABLE_WELLFOUND=true
ENABLE_X=false
ENABLE_REDDIT=true
ENABLE_HN=true
ENABLE_GITHUB=true
ENABLE_REDDIT_TASKS=true

# ─── Logging ───
LOG_LEVEL=INFO

